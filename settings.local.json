{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(supabase:*)",
      "Bash(vercel:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(curl:*)",
      "Bash(chmod:*)",
      "Bash(pytest:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(brew:*)",
      "Bash(tmux:*)",
      "Bash(memory_pressure:*)",
      "Bash(claude --version:*)",
      "Bash(cd:*)",
      "Bash(PYTHONIOENCODING=utf-8 python3:*)",
      "Bash(npm install:*)",
      "Bash(rsync:*)",
      "Bash(unzip:*)",
      "Bash(diff:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(xargs:*)",
      "Bash(open:*)",
      "Bash(gws:*)",
      "Bash(playwright-cli:*)",
      "Bash(sentry-cli:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:raizeducacao.com.br)",
      "WebFetch(domain:www.brandcolorcode.com)",
      "WebFetch(domain:brandfetch.com)",
      "WebFetch(domain:www.fundacaovale.org)",
      "WebFetch(domain:midiasstoragesec.blob.core.windows.net)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Bash(cat .env*)",
      "Bash(cat **/.env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'pkill -f terminal-notifier 2>/dev/null; REPO=$(git rev-parse --show-toplevel 2>/dev/null | xargs basename 2>/dev/null || echo \"claude\"); BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \"-\"); nohup terminal-notifier -title \"Claude Code\" -subtitle \"$REPO ($BRANCH)\" -message \"Needs your input\" -sender com.anthropic.claudefordesktop -sound Glass >/dev/null 2>&1 & disown; afplay /System/Library/Sounds/Glass.aiff 2>/dev/null &disown'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/scripts/cleanup-orphans.sh 2>/dev/null",
            "statusMessage": "Cleaning orphaned processes..."
          }
        ]
      }
    ],
    "Stop": [],
    "SubagentStop": [],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"PRESERVE: modified files, current task, test commands, errors found\" >&2'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/secret-scan.sh 2>/dev/null || true",
            "statusMessage": "Secret scan..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/parallel-agent-guard-cleanup.sh 2>/dev/null || true",
            "statusMessage": "Release parallel agent lock..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "TeamCreate|TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/scripts/memory-guard.sh >/dev/null 2>&1; EXIT=$?; if [ $EXIT -eq 2 ]; then echo 'BLOCKED: Memory pressure CRITICAL. Fechar sessoes/terminais antes de spawnar novos agents. Rode: bash ~/Claude/.claude/scripts/memory-guard.sh para detalhes.'; exit 2; elif [ $EXIT -eq 1 ]; then echo 'WARNING: Memory pressure elevada. Considere aguardar agents atuais terminarem antes de spawnar novos.'; fi",
            "statusMessage": "Memory guard check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/bash-guards.sh",
            "statusMessage": "Bash safety guards..."
          },
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/branch-guard.sh",
            "statusMessage": "Branch protection guard..."
          },
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/parallel-agent-guard.sh",
            "statusMessage": "Parallel agent lock check..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/config-guard.sh",
            "statusMessage": "Config protection guard..."
          }
        ]
      }
    ]
  }
}
