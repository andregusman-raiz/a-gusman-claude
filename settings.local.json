  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'pkill -f terminal-notifier 2>/dev/null; REPO=$(git rev-parse --show-toplevel 2>/dev/null | xargs basename 2>/dev/null || echo \"claude\"); BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \"-\"); nohup terminal-notifier -title \"Claude Code\" -subtitle \"$REPO ($BRANCH)\" -message \"Needs your input\" -sender com.anthropic.claudefordesktop -sound Glass >/dev/null 2>&1 & disown; afplay /System/Library/Sounds/Glass.aiff 2>/dev/null &disown'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/scripts/cleanup-orphans.sh 2>/dev/null",
            "statusMessage": "Cleaning orphaned processes..."
          }
        ]
      }
    ],
    "Stop": [],
    "SubagentStop": [],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"PRESERVE: modified files, current task, test commands, errors found\" >&2'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/secret-scan.sh 2>/dev/null || true",
            "statusMessage": "Secret scan..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/parallel-agent-guard-cleanup.sh 2>/dev/null || true",
            "statusMessage": "Release parallel agent lock..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "TeamCreate|TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/scripts/memory-guard.sh >/dev/null 2>&1; EXIT=$?; if [ $EXIT -eq 2 ]; then echo 'BLOCKED: Memory pressure CRITICAL. Fechar sessoes/terminais antes de spawnar novos agents. Rode: bash ~/Claude/.claude/scripts/memory-guard.sh para detalhes.'; exit 2; elif [ $EXIT -eq 1 ]; then echo 'WARNING: Memory pressure elevada. Considere aguardar agents atuais terminarem antes de spawnar novos.'; fi",
            "statusMessage": "Memory guard check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/bash-guards.sh",
            "statusMessage": "Bash safety guards..."
          },
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/branch-guard.sh",
            "statusMessage": "Branch protection guard..."
          },
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/parallel-agent-guard.sh",
            "statusMessage": "Parallel agent lock check..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Claude/.claude/hooks/config-guard.sh",
            "statusMessage": "Config protection guard..."
          }
        ]
      }
    ]
  }
