{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-update.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/security-gate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/branch-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/parallel-agent-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/parallel-agent-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-scan.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/shared/sync.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/worktree-prune.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
