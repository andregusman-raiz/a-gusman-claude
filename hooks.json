{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/preflight-check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/security-gate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/branch-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-push-check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash /Users/andregusmandeoliveira/Claude/.claude/hooks/quality-trend-check.sh \"$TOOL_INPUT\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-guard.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/sdd-enforcement.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-format.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-after-edit.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-scan.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash /Users/andregusmandeoliveira/Claude/.claude/hooks/otel-span-check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash /Users/andregusmandeoliveira/Claude/.claude/hooks/smart-test-suggest.sh 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash /Users/andregusmandeoliveira/Claude/.claude/hooks/post-deploy-monitor.sh \"$TOOL_INPUT\" 2>/dev/null || true",
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "bash /Users/andregusmandeoliveira/Claude/.claude/hooks/error-context-enricher.sh \"$TOOL_OUTPUT\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/quality-check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .shared/sync.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
